{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "BettingSettings": {
    // Starting bankroll in dollars
    "InitialBankroll": 10000,

    // Kelly fraction: 0.5 = half-Kelly (recommended), 0.25 = conservative
    "KellyFraction": 0.5,

    // Rule #3: Max stake per single bet as a fraction of bankroll (3%)
    "MaxStakePercent": 0.03,

    // Rule #4: Stop betting for the day if daily loss exceeds this fraction (10%)
    "DailyLossLimitPercent": 0.10,

    // Rule #5: Halt system entirely if cumulative loss exceeds this fraction (20%)
    "StopLossPercent": 0.20,

    // Rule #2: Minimum model edge required to flag a bet opportunity (5%)
    "EdgeThreshold": 0.05,

    // Rule #1: Only consider matches starting this many hours in the future
    "PreMatchMinHoursAhead": 1.0,

    // Supported sports (informational — used by frontend tabs)
    "SupportedSports": [ "EPL", "AFL", "NRL", "NBA", "Esports" ],

    // Real odds API key from https://the-odds-api.com (free tier: 500 req/month)
    // Leave empty ("") to use built-in mock data instead
    "OddsApiKey": "83adb5b0a78da150343724661e2e429f"
  }
}
